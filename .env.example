# =============================================================================
# CORE
# =============================================================================

# Stack directory on the server
NAS_STACK_DIR=/volume1/docker/arr-stack

# Media storage root
MEDIA_ROOT=/volume1/data

# Timezone
TZ=Australia/Sydney

# User/Group IDs (check with: id -u && id -g)
PUID=1000
PGID=1000

# Intel Quick Sync render group (optional - leave blank to skip)
RENDER_GROUP_ID=

# =============================================================================
# TAILSCALE
# =============================================================================

# LAN subnet to advertise routes for
LAN_SUBNET=10.10.0.0/24

# Node hostname in admin console
# TS_HOSTNAME=arr-stack-vps

# Pre-auth key for unattended setup
# TS_AUTHKEY=tskey-auth-xxxxxxxxxxxx

# Extra subnets to advertise (comma-separated)
TS_EXTRA_ROUTES=172.20.0.0/24

# =============================================================================
# UTILITIES (optional)
# =============================================================================

# Beszel agent key
# BESZEL_KEY=

# DIUN webhook URL for update notifications
# DIUN_WEBHOOK_URL=

# Configarr API keys
# SONARR_API_KEY=
# RADARR_API_KEY=

# =============================================================================
# QBITTORRENT
# =============================================================================

# Web UI credentials (used by configure-apps.sh and Sonarr/Radarr integration)
QBIT_USERNAME=admin
QBIT_PASSWORD=adminadmin
